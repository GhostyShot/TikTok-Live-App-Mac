{
  "name": "tiklive-studio",
  "version": "1.0.0",
  "description": "TikTok LIVE Dashboard — Events, Overlays, Keystroke Automation",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "me.paulfaller.tiklive-studio",
    "productName": "TikLive Studio",
    "copyright": "Copyright © 2025 Paul Faller",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "TikLive Studio",
      "background": "assets/dmg-background.png",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": ["src/**/*", "assets/**/*", "node_modules/**/*"],
    "asar": true,
    "asarUnpack": []
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "tiktok-live-connector": "^2.1.1-beta1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "author": "Paul Faller",
  "license": "MIT"
}
